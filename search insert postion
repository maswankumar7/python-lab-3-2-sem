class Solution:
    def binarySearch(self, nums, target):
        (left, right) = (0, len(nums) - 1)
        
        while left <= right:
            mid = (left + right) // 2

            if target == nums[mid]:
                return mid
            elif target  < nums[mid]:
                right = mid - 1
            else:
                left = mid + 1
        
        return left

    def searchInsert(self, nums: List[int], target: int) -> int:
        # binary search
        return self.binarySearch(nums, target)
        
